  "__export_source": "rappidrive-backend",
  "resources": [
    {
      "_id": "wrk_rappidrive",
      "_type": "workspace",
      "name": "RappiDrive Backend",
      "description": "Collection completa da API RappiDrive — plataforma white-label de ride-hailing",
      "scope": "collection"
    },
    {
      "_id": "env_base",
      "_type": "environment",
      "parentId": "wrk_rappidrive",
      "name": "Local Dev",
      "data": {
        "base_url": "http://localhost:8080",
        "keycloak_url": "http://localhost:8180",
        "realm": "rappidrive-test",
        "client_id": "rappidrive-api",
        "client_secret": "test-secret",
        "tenant_id": "11111111-1111-1111-1111-111111111111",
        "token_passenger": "<cole aqui o token do passenger-test>",
        "token_driver": "<cole aqui o token do driver-test>",
        "token_admin": "<cole aqui o token do admin-test>",
        "passenger_id": "<cole o UUID do passageiro criado>",
        "driver_id": "<cole o UUID do motorista criado>",
        "vehicle_id": "<cole o UUID do veículo criado>",
        "trip_id": "<cole o UUID da viagem criada>",
        "payment_id": "<cole o UUID do pagamento criado>",
        "rating_id": "<cole o UUID da avaliação criada>",
        "notification_id": "<cole o UUID da notificação criada>",
        "approval_id": "<cole o UUID da aprovação criada>"
      },
      "color": "#4CAF50"
    },

    {
      "_id": "fld_auth",
      "_type": "request_group",
      "parentId": "wrk_rappidrive",
      "name": "🔐 Autenticação (Keycloak)",
      "description": "Obtenção de tokens JWT para cada role"
    },
    {
      "_id": "req_auth_passenger",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "Token — passenger-test (ROLE_PASSENGER)",
      "method": "POST",
      "url": "{{ keycloak_url }}/realms/{{ realm }}/protocol/openid-connect/token",
      "headers": [
        { "name": "Content-Type", "value": "application/x-www-form-urlencoded" }
      ],
      "body": {
        "mimeType": "application/x-www-form-urlencoded",
        "params": [
          { "name": "grant_type",    "value": "password" },
          { "name": "client_id",     "value": "{{ client_id }}" },
          { "name": "client_secret", "value": "{{ client_secret }}" },
          { "name": "username",      "value": "passenger-test" },
          { "name": "password",      "value": "passenger123" }
        ]
      },
      "authentication": {},
      "description": "Copie o access_token e cole na variável de ambiente token_passenger"
    },
    {
      "_id": "req_auth_driver",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "Token — driver-test (ROLE_DRIVER)",
      "method": "POST",
      "url": "{{ keycloak_url }}/realms/{{ realm }}/protocol/openid-connect/token",
      "headers": [
        { "name": "Content-Type", "value": "application/x-www-form-urlencoded" }
      ],
      "body": {
        "mimeType": "application/x-www-form-urlencoded",
        "params": [
          { "name": "grant_type",    "value": "password" },
          { "name": "client_id",     "value": "{{ client_id }}" },
          { "name": "client_secret", "value": "{{ client_secret }}" },
          { "name": "username",      "value": "driver-test" },
          { "name": "password",      "value": "driver123" }
        ]
      },
      "authentication": {},
      "description": "Copie o access_token e cole na variável de ambiente token_driver"
    },
    {
      "_id": "req_auth_admin",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "Token — admin-test (ROLE_ADMIN)",
      "method": "POST",
      "url": "{{ keycloak_url }}/realms/{{ realm }}/protocol/openid-connect/token",
      "headers": [
        { "name": "Content-Type", "value": "application/x-www-form-urlencoded" }
      ],
      "body": {
        "mimeType": "application/x-www-form-urlencoded",
        "params": [
          { "name": "grant_type",    "value": "password" },
          { "name": "client_id",     "value": "{{ client_id }}" },
          { "name": "client_secret", "value": "{{ client_secret }}" },
          { "name": "username",      "value": "admin-test" },
          { "name": "password",      "value": "admin123" }
        ]
      },
      "authentication": {},
      "description": "Copie o access_token e cole na variável de ambiente token_admin"
    },
    {
      "_id": "req_auth_client_credentials",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "Token — client_credentials (service account)",
      "method": "POST",
      "url": "{{ keycloak_url }}/realms/{{ realm }}/protocol/openid-connect/token",
      "headers": [
        { "name": "Content-Type", "value": "application/x-www-form-urlencoded" }
      ],
      "body": {
        "mimeType": "application/x-www-form-urlencoded",
        "params": [
          { "name": "grant_type",    "value": "client_credentials" },
          { "name": "client_id",     "value": "{{ client_id }}" },
          { "name": "client_secret", "value": "{{ client_secret }}" }
        ]
      },
      "authentication": {}
    },

    {
      "_id": "fld_health",
      "_type": "request_group",
      "parentId": "wrk_rappidrive",
      "name": "🏥 Saúde e Monitoramento",
      "description": "Endpoints de health check e métricas"
    },
    {
      "_id": "req_actuator_health",
      "_type": "request",
      "parentId": "fld_health",
      "name": "Actuator Health",
      "method": "GET",
      "url": "{{ base_url }}/actuator/health",
      "headers": [],
      "authentication": {}
    },
    {
      "_id": "req_actuator_prometheus",
      "_type": "request",
      "parentId": "fld_health",
      "name": "Actuator Prometheus Metrics",
      "method": "GET",
      "url": "{{ base_url }}/actuator/prometheus",
      "headers": [],
      "authentication": {}
    },
    {
      "_id": "req_api_health",
      "_type": "request",
      "parentId": "fld_health",
      "name": "API Health Check",
      "method": "GET",
      "url": "{{ base_url }}/api/health",
      "headers": [],
      "authentication": {}
    },

    {
      "_id": "fld_admin_tenants",
      "_type": "request_group",
      "parentId": "wrk_rappidrive",
      "name": "🏢 Admin — Tenants (Super Admin)",
      "description": "Endpoints de gestão de tenants. Requer ROLE_SUPER_ADMIN."
    },
    {
      "_id": "req_tenant_onboard",
      "_type": "request",
      "parentId": "fld_admin_tenants",
      "name": "POST Onboard Tenant",
      "method": "POST",
      "url": "{{ base_url }}/api/admin/tenants",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_admin }}"
      },
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"tenantId\": \"aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee\",\n  \"displayName\": \"RappiDrive São Paulo\",\n  \"adminEmail\": \"admin@saopaulo.rappidrive.com\",\n  \"currency\": \"BRL\",\n  \"baseFare\": 5.00,\n  \"pricePerKm\": 2.50,\n  \"pricePerMin\": 0.30,\n  \"serviceAreaName\": \"São Paulo\",\n  \"geoJsonPolygon\": \"{\\\"type\\\":\\\"Polygon\\\",\\\"coordinates\\\":[[[-46.826171875,-23.885837699862005],[-46.560058593750004,-23.885837699862005],[-46.560058593750004,-23.592263984320745],[-46.826171875,-23.592263984320745],[-46.826171875,-23.885837699862005]]]}\"\n}"
      },
      "description": "Provisiona um novo tenant na plataforma. Cria admin no Keycloak, configura tarifas e área de serviço. Requer ROLE_SUPER_ADMIN."
    },
    {
      "_id": "req_tenant_health",
      "_type": "request",
      "parentId": "fld_admin_tenants",
      "name": "GET Admin Health Check",
      "method": "GET",
      "url": "{{ base_url }}/api/admin/tenants/health",
      "headers": [],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_admin }}"
      }
    },

    {
      "_id": "fld_admin_fare_config",
      "_type": "request_group",
      "parentId": "wrk_rappidrive",
      "name": "💰 Admin — Configuração de Tarifas",
      "description": "Gestão de tarifas por tenant. Requer ROLE_ADMIN."
    },
    {
      "_id": "req_fare_config_get",
      "_type": "request",
      "parentId": "fld_admin_fare_config",
      "name": "GET Configuração de Tarifa por Tenant",
      "method": "GET",
      "url": "{{ base_url }}/api/v1/admin/fare-configurations/tenant/{{ tenant_id }}",
      "headers": [
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_admin }}"
      }
    },
    {
      "_id": "req_fare_config_update",
      "_type": "request",
      "parentId": "fld_admin_fare_config",
      "name": "PUT Atualizar Configuração de Tarifa",
      "method": "PUT",
      "url": "{{ base_url }}/api/v1/admin/fare-configurations",
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_admin }}"
      },
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"tenantId\": \"{{ tenant_id }}\",\n  \"baseFare\": 5.00,\n  \"pricePerKm\": 2.50,\n  \"pricePerMinute\": 0.30,\n  \"minimumFare\": 8.00,\n  \"platformCommissionRate\": 0.20\n}"
      }
    },

    {
      "_id": "fld_admin_approvals",
      "_type": "request_group",
      "parentId": "wrk_rappidrive",
      "name": "✅ Admin — Aprovações de Motoristas",
      "description": "Fluxo de aprovação de cadastro de motoristas. Requer ROLE_ADMIN."
    },
    {
      "_id": "req_approval_submit",
      "_type": "request",
      "parentId": "fld_admin_approvals",
      "name": "POST Submeter Aprovação",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/admin/approvals",
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_driver }}"
      },
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"driverId\": \"{{ driver_id }}\",\n  \"documentUrls\": [\n    \"https://docs.example.com/cnh-frente.jpg\",\n    \"https://docs.example.com/cnh-verso.jpg\",\n    \"https://docs.example.com/documento-veiculo.jpg\"\n  ]\n}"
      },
      "description": "Motorista submete documentos para aprovação. Cole o driver_id na variável de ambiente após criar o motorista."
    },
    {
      "_id": "req_approval_list_pending",
      "_type": "request",
      "parentId": "fld_admin_approvals",
      "name": "GET Listar Aprovações Pendentes",
      "method": "GET",
      "url": "{{ base_url }}/api/v1/admin/approvals/pending?page=0&size=10",
      "headers": [
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_admin }}"
      }
    },
    {
      "_id": "req_approval_approve",
      "_type": "request",
      "parentId": "fld_admin_approvals",
      "name": "POST Aprovar Motorista",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/admin/approvals/{{ approval_id }}/approve",
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_admin }}"
      },
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"adminId\": null\n}"
      },
      "description": "adminId é extraído automaticamente do JWT quando autenticado."
    },
    {
      "_id": "req_approval_reject",
      "_type": "request",
      "parentId": "fld_admin_approvals",
      "name": "POST Rejeitar Motorista",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/admin/approvals/{{ approval_id }}/reject",
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_admin }}"
      },
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"adminId\": null,\n  \"rejectionReason\": \"Documentação incompleta ou ilegível\",\n  \"permanentBan\": false\n}"
      }
    },

    {
      "_id": "fld_passengers",
      "_type": "request_group",
      "parentId": "wrk_rappidrive",
      "name": "👤 Passageiros",
      "description": "Gestão de passageiros. Requer ROLE_PASSENGER."
    },
    {
      "_id": "req_passenger_create",
      "_type": "request",
      "parentId": "fld_passengers",
      "name": "POST Criar Passageiro",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/passengers",
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_passenger }}"
      },
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"tenantId\": \"{{ tenant_id }}\",\n  \"fullName\": \"Maria da Silva Santos\",\n  \"email\": \"maria.silva@example.com\",\n  \"phone\": \"+5511988880001\"\n}"
      },
      "description": "Cria um novo passageiro. Salve o id retornado na variável passenger_id."
    },
    {
      "_id": "req_passenger_get",
      "_type": "request",
      "parentId": "fld_passengers",
      "name": "GET Buscar Passageiro por ID",
      "method": "GET",
      "url": "{{ base_url }}/api/v1/passengers/{{ passenger_id }}",
      "headers": [
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_passenger }}"
      }
    },

    {
      "_id": "fld_drivers",
      "_type": "request_group",
      "parentId": "wrk_rappidrive",
      "name": "🚗 Motoristas",
      "description": "Gestão de motoristas. Requer ROLE_DRIVER."
    },
    {
      "_id": "req_driver_create",
      "_type": "request",
      "parentId": "fld_drivers",
      "name": "POST Criar Motorista",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/drivers",
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_driver }}"
      },
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"tenantId\": \"{{ tenant_id }}\",\n  \"fullName\": \"Carlos Eduardo Silva\",\n  \"email\": \"carlos.silva@example.com\",\n  \"cpf\": \"11144477735\",\n  \"phone\": \"+5511977770001\",\n  \"driverLicense\": {\n    \"number\": \"12345678901\",\n    \"category\": \"B\",\n    \"issueDate\": \"2020-01-15\",\n    \"expiryDate\": \"2030-01-15\",\n    \"isDefinitive\": true\n  }\n}"
      },
      "description": "CPF deve conter exatamente 11 dígitos (sem pontuação). Salve o id retornado na variável driver_id."
    },
    {
      "_id": "req_driver_get",
      "_type": "request",
      "parentId": "fld_drivers",
      "name": "GET Buscar Motorista por ID",
      "method": "GET",
      "url": "{{ base_url }}/api/v1/drivers/{{ driver_id }}",
      "headers": [
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_driver }}"
      }
    },
    {
      "_id": "req_driver_activate",
      "_type": "request",
      "parentId": "fld_drivers",
      "name": "PUT Ativar Motorista",
      "method": "PUT",
      "url": "{{ base_url }}/api/v1/drivers/{{ driver_id }}/activate",
      "headers": [
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_driver }}"
      }
    },
    {
      "_id": "req_driver_location",
      "_type": "request",
      "parentId": "fld_drivers",
      "name": "PUT Atualizar Localização do Motorista",
      "method": "PUT",
      "url": "{{ base_url }}/api/v1/drivers/{{ driver_id }}/location",
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_driver }}"
      },
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"location\": {\n    \"latitude\": -23.55052,\n    \"longitude\": -46.633308\n  }\n}"
      },
      "description": "Motorista deve estar ACTIVE para atualizar localização."
    },
    {
      "_id": "req_driver_nearby",
      "_type": "request",
      "parentId": "fld_drivers",
      "name": "GET Motoristas Próximos (PostGIS KNN)",
      "method": "GET",
      "url": "{{ base_url }}/api/v1/drivers/nearby?tenantId={{ tenant_id }}&latitude=-23.55052&longitude=-46.633308&radiusKm=5.0",
      "headers": [
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_driver }}"
      },
      "description": "Busca motoristas disponíveis num raio usando ST_DWithin + KNN. Default radiusKm=5.0."
    },
    {
      "_id": "req_driver_available",
      "_type": "request",
      "parentId": "fld_drivers",
      "name": "GET Motoristas Disponíveis",
      "method": "GET",
      "url": "{{ base_url }}/api/v1/drivers/available",
      "headers": [
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_driver }}"
      }
    },

