      }
    },
    {
      "_id": "req_vehicle_activate",
      "_type": "request",
      "parentId": "fld_vehicles",
      "name": "PUT Ativar Veículo",
      "method": "PUT",
      "url": "{{ base_url }}/api/v1/vehicles/{{ vehicle_id }}/activate",
      "headers": [
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_driver }}"
      }
    },

    {
      "_id": "fld_trips",
      "_type": "request_group",
      "parentId": "wrk_rappidrive",
      "name": "🗺️ Viagens",
      "description": "Ciclo de vida completo de uma viagem. Requer autenticação."
    },
    {
      "_id": "req_trip_create",
      "_type": "request",
      "parentId": "fld_trips",
      "name": "POST Criar Viagem",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/trips",
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_passenger }}"
      },
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"tenantId\": \"{{ tenant_id }}\",\n  \"passengerId\": \"{{ passenger_id }}\",\n  \"origin\": {\n    \"latitude\": -23.55052,\n    \"longitude\": -46.633308\n  },\n  \"destination\": {\n    \"latitude\": -23.561414,\n    \"longitude\": -46.656056\n  }\n}"
      },
      "description": "Cria viagem com status REQUESTED. Salve o id em trip_id."
    },
    {
      "_id": "req_trip_get",
      "_type": "request",
      "parentId": "fld_trips",
      "name": "GET Buscar Viagem por ID",
      "method": "GET",
      "url": "{{ base_url }}/api/v1/trips/{{ trip_id }}",
      "headers": [
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_passenger }}"
      }
    },
    {
      "_id": "req_trip_assign_driver",
      "_type": "request",
      "parentId": "fld_trips",
      "name": "PUT Atribuir Motorista à Viagem",
      "method": "PUT",
      "url": "{{ base_url }}/api/v1/trips/{{ trip_id }}/assign-driver",
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_driver }}"
      },
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"driverId\": \"{{ driver_id }}\"\n}"
      },
      "description": "Viagem deve estar em status REQUESTED. Motorista deve estar ACTIVE."
    },
    {
      "_id": "req_trip_start",
      "_type": "request",
      "parentId": "fld_trips",
      "name": "PUT Iniciar Viagem",
      "method": "PUT",
      "url": "{{ base_url }}/api/v1/trips/{{ trip_id }}/start",
      "headers": [
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_driver }}"
      },
      "description": "Viagem deve estar em status DRIVER_ASSIGNED."
    },
    {
      "_id": "req_trip_complete",
      "_type": "request",
      "parentId": "fld_trips",
      "name": "PUT Concluir Viagem (sem pagamento)",
      "method": "PUT",
      "url": "{{ base_url }}/api/v1/trips/{{ trip_id }}/complete",
      "headers": [
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_driver }}"
      },
      "description": "Conclui a viagem sem processar pagamento. Viagem deve estar em status IN_PROGRESS."
    },
    {
      "_id": "req_trip_complete_with_payment",
      "_type": "request",
      "parentId": "fld_trips",
      "name": "POST Concluir Viagem com Pagamento",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/trips/{{ trip_id }}/complete-with-payment",
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_driver }}"
      },
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"dropoffLocation\": {\n    \"latitude\": -23.561414,\n    \"longitude\": -46.656056\n  },\n  \"paymentMethod\": {\n    \"type\": \"CREDIT_CARD\",\n    \"cardLast4\": \"4242\",\n    \"cardBrand\": \"Visa\",\n    \"pixKey\": null\n  }\n}"
      },
      "description": "Calcula tarifa automaticamente e processa pagamento. type: CREDIT_CARD | DEBIT_CARD | PIX | CASH."
    },
    {
      "_id": "req_trip_payment_details",
      "_type": "request",
      "parentId": "fld_trips",
      "name": "GET Detalhes da Viagem com Pagamento",
      "method": "GET",
      "url": "{{ base_url }}/api/v1/trips/{{ trip_id }}/payment-details",
      "headers": [
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_passenger }}"
      }
    },
    {
      "_id": "req_trip_cancel",
      "_type": "request",
      "parentId": "fld_trips",
      "name": "POST Cancelar Viagem",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/trips/{{ trip_id }}/cancel",
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_passenger }}"
      },
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"reason\": \"PASSENGER_CHANGE_OF_PLANS\",\n  \"additionalNotes\": \"Cancelado por teste\"\n}"
      },
      "description": "Motivos do passageiro: PASSENGER_CHANGE_OF_PLANS | PASSENGER_PRICE_TOO_HIGH | PASSENGER_WAIT_TOO_LONG | PASSENGER_WRONG_LOCATION | PASSENGER_OTHER. Motivos do motorista: DRIVER_PASSENGER_NOT_FOUND | DRIVER_UNSAFE_LOCATION | DRIVER_VEHICLE_ISSUE | DRIVER_OTHER."
    },

    {
      "_id": "fld_fares",
      "_type": "request_group",
      "parentId": "wrk_rappidrive",
      "name": "🧮 Tarifas",
      "description": "Cálculo de tarifas. Requer FareConfiguration cadastrada para o tenant."
    },
    {
      "_id": "req_fare_calculate",
      "_type": "request",
      "parentId": "fld_fares",
      "name": "POST Calcular Tarifa",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/fares/calculate",
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_driver }}"
      },
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"tenantId\": \"{{ tenant_id }}\",\n  \"distanceInKm\": 5.2,\n  \"durationInMinutes\": 18,\n  \"tripStartTime\": \"2026-04-24T15:00:00\",\n  \"vehicleType\": \"SEDAN\"\n}"
      },
      "description": "vehicleType: SEDAN | HATCHBACK | SUV. Requer FareConfiguration existente para o tenant (criada via onboard ou PUT /admin/fare-configurations)."
    },

    {
      "_id": "fld_payments",
      "_type": "request_group",
      "parentId": "wrk_rappidrive",
      "name": "💳 Pagamentos",
      "description": "Processamento e consulta de pagamentos. Requer autenticação."
    },
    {
      "_id": "req_payment_process",
      "_type": "request",
      "parentId": "fld_payments",
      "name": "POST Processar Pagamento",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/payments",
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_driver }}"
      },
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"tenantId\": \"{{ tenant_id }}\",\n  \"tripId\": \"{{ trip_id }}\",\n  \"amount\": 32.50,\n  \"paymentMethodType\": \"CREDIT_CARD\",\n  \"cardLast4\": \"4242\",\n  \"cardBrand\": \"Visa\",\n  \"pixKey\": null\n}"
      },
      "description": "paymentMethodType: CREDIT_CARD | DEBIT_CARD | PIX | CASH. Salve o id em payment_id."
    },
    {
      "_id": "req_payment_get",
      "_type": "request",
      "parentId": "fld_payments",
      "name": "GET Buscar Pagamento por ID",
      "method": "GET",
      "url": "{{ base_url }}/api/v1/payments/{{ payment_id }}",
      "headers": [
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_driver }}"
      }
    },
    {
      "_id": "req_payment_by_trip",
      "_type": "request",
      "parentId": "fld_payments",
      "name": "GET Buscar Pagamento por Viagem",
      "method": "GET",
      "url": "{{ base_url }}/api/v1/payments/trip/{{ trip_id }}",
      "headers": [
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_driver }}"
      }
    },
    {
      "_id": "req_payment_by_period",
      "_type": "request",
      "parentId": "fld_payments",
      "name": "GET Pagamentos por Tenant e Período",
      "method": "GET",
      "url": "{{ base_url }}/api/v1/payments/tenant/{{ tenant_id }}/period?startDate=2026-04-01T00:00:00&endDate=2026-04-30T23:59:59",
      "headers": [
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_admin }}"
      }
    },
    {
      "_id": "req_payment_refund",
      "_type": "request",
      "parentId": "fld_payments",
      "name": "POST Reembolsar Pagamento",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/payments/refund",
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_admin }}"
      },
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"paymentId\": \"{{ payment_id }}\",\n  \"reason\": \"Solicitação do passageiro após cancelamento\"\n}"
      },
      "description": "Disponível apenas para métodos reembolsáveis: CREDIT_CARD, DEBIT_CARD, PIX. CASH não é reembolsável."
    },

    {
      "_id": "fld_ratings",
      "_type": "request_group",
      "parentId": "wrk_rappidrive",
      "name": "⭐ Avaliações",
      "description": "Sistema de avaliação bidirecional. Requer autenticação."
    },
    {
      "_id": "req_rating_create",
      "_type": "request",
      "parentId": "fld_ratings",
      "name": "POST Criar Avaliação",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/ratings?rateeId={{ driver_id }}",
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" },
        { "name": "X-User-Id", "value": "{{ passenger_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_passenger }}"
      },
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"tripId\": \"{{ trip_id }}\",\n  \"score\": 5,\n  \"comment\": \"Ótimo motorista, pontual e educado!\"\n}"
      },
      "description": "score: 1-5. rateeId (query param) = quem está sendo avaliado. X-User-Id = quem avalia. Salve o id em rating_id."
    },
    {
      "_id": "req_rating_driver_summary",
      "_type": "request",
      "parentId": "fld_ratings",
      "name": "GET Resumo de Avaliações do Motorista",
      "method": "GET",
      "url": "{{ base_url }}/api/v1/ratings/drivers/{{ driver_id }}/summary",
      "headers": [
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_driver }}"
      }
    },
    {
      "_id": "req_rating_passenger",
      "_type": "request",
      "parentId": "fld_ratings",
      "name": "GET Avaliação do Passageiro",
      "method": "GET",
      "url": "{{ base_url }}/api/v1/ratings/passengers/{{ passenger_id }}",
      "headers": [
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_driver }}"
      }
    },
    {
      "_id": "req_rating_trip",
      "_type": "request",
      "parentId": "fld_ratings",
      "name": "GET Avaliações da Viagem",
      "method": "GET",
      "url": "{{ base_url }}/api/v1/ratings/trips/{{ trip_id }}",
      "headers": [
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_passenger }}"
      }
    },
    {
      "_id": "req_rating_report",
      "_type": "request",
      "parentId": "fld_ratings",
      "name": "POST Reportar Avaliação Ofensiva",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/ratings/{{ rating_id }}/report",
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" },
        { "name": "X-User-Id", "value": "{{ driver_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_driver }}"
      },
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"reason\": \"Comentário ofensivo e inapropriado\"\n}"
      }
    },

    {
      "_id": "fld_notifications",
      "_type": "request_group",
      "parentId": "wrk_rappidrive",
      "name": "🔔 Notificações",
      "description": "Sistema de notificações. Requer autenticação. Headers X-User-Id e X-Tenant-Id obrigatórios."
    },
    {
      "_id": "req_notification_send",
      "_type": "request",
      "parentId": "fld_notifications",
      "name": "POST Enviar Notificação",
      "method": "POST",
      "url": "{{ base_url }}/api/v1/notifications",
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" },
        { "name": "X-Tenant-Id", "value": "{{ tenant_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_admin }}"
      },
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"userId\": \"{{ passenger_id }}\",\n  \"title\": \"Sua viagem está a caminho!\",\n  \"message\": \"Motorista Carlos está a 3 minutos de você.\",\n  \"idempotencyKey\": \"trip-{{ trip_id }}-driver-assigned\"\n}"
      },
      "description": "Nota: este controller usa o header X-Tenant-Id (com 'd' minúsculo), diferente dos demais que usam X-Tenant-ID."
    },
    {
      "_id": "req_notification_list",
      "_type": "request",
      "parentId": "fld_notifications",
      "name": "GET Listar Notificações do Usuário",
      "method": "GET",
      "url": "{{ base_url }}/api/v1/notifications?status=UNREAD&page=0&size=20",
      "headers": [
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" },
        { "name": "X-Tenant-Id", "value": "{{ tenant_id }}" },
        { "name": "X-User-Id", "value": "{{ passenger_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_passenger }}"
      },
      "description": "status (opcional): UNREAD | READ | ALL"
    },
    {
      "_id": "req_notification_unread_count",
      "_type": "request",
      "parentId": "fld_notifications",
      "name": "GET Contador de Não Lidas",
      "method": "GET",
      "url": "{{ base_url }}/api/v1/notifications/unread-count",
      "headers": [
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" },
        { "name": "X-Tenant-Id", "value": "{{ tenant_id }}" },
        { "name": "X-User-Id", "value": "{{ passenger_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_passenger }}"
      }
    },
    {
      "_id": "req_notification_mark_read",
      "_type": "request",
      "parentId": "fld_notifications",
      "name": "PATCH Marcar como Lida",
      "method": "PATCH",
      "url": "{{ base_url }}/api/v1/notifications/{{ notification_id }}/read",
      "headers": [
        { "name": "X-Tenant-ID", "value": "{{ tenant_id }}" },
        { "name": "X-Tenant-Id", "value": "{{ tenant_id }}" },
        { "name": "X-User-Id", "value": "{{ passenger_id }}" }
      ],
      "authentication": {
        "type": "bearer",
        "token": "{{ token_passenger }}"
      }
    }
  ]
}
